{#- Shared site chrome: skip-link + sticky header with CSS-only hamburger.
    The #navtoggle checkbox sits in the DOM BEFORE <nav> so the pure-CSS
    sibling selector `#navtoggle:checked ~ nav.main` can reveal the menu on
    mobile. No JS, no inline styles -> CSP-safe. Visual order via `order`
    in style.css. -#}
<a class="skip" href="#main">{{ strings.skip }}</a>
{%- if minimalHeader %}
{#- Reduzierter Header für Kampagnen-Landingpages (Spec Teil C): nur Logo +
    Telefon, keine Nav, keine Cross-Links -> ein einziges Ziel. -#}
<header class="site minimal">
  <div class="wrap">
    <a class="wordmark" href="{{ strings.home }}"><img src="{{ site.logo }}" alt="" width="28" height="28" /> Kozlowski <span>IT</span></a>
    <div class="switches">
      <a class="nav-tel" href="{{ site.telHref }}"><span aria-hidden="true">&#128222;</span> {{ site.telDisplay }}</a>
      <button id="theme-toggle" type="button" aria-label="{{ strings.themeToggle }}">☾</button>
    </div>
  </div>
</header>
{%- else %}
<header class="site">
  <div class="wrap">
    <a class="wordmark" href="{{ strings.home }}"><img src="{{ site.logo }}" alt="" width="28" height="28" /> Kozlowski <span>IT</span></a>
    <input type="checkbox" id="navtoggle" class="nav-toggle-cb" />
    <label for="navtoggle" class="nav-toggle" aria-label="{{ strings.menuOpen }}"></label>
    {%- include "partials/nav.njk" %}
    <a class="nav-tel header-tel" href="{{ site.telHref }}"><span aria-hidden="true">&#128222;</span> {{ site.telDisplay }}</a>
    <div class="switches">
      <a class="portal-btn" href="{{ site.portal }}">{{ strings.portal }}</a>
      <a class="lang" href="{{ altLangUrl or strings.langSwitch.fallback }}" lang="{{ strings.langSwitch.code }}" aria-label="{{ strings.langSwitch.aria }}">{{ strings.langSwitch.label }}</a>
      <button id="theme-toggle" type="button" aria-label="{{ strings.themeToggle }}">☾</button>
    </div>
  </div>
</header>
{%- endif %}
