            <input type="number" id="r-cores" min="1" step="1" value="16" inputmode="numeric" />
          </label>
        </div>

        <fieldset class="r-kostenweg">
          <legend>Aktuelle VMware-Kosten</legend>
          <label class="r-radio"><input type="radio" name="kostenweg" value="bekannt" checked /> <span>Ich kenne meine Summe (vom Verlängerungsangebot)</span></label>
          <label class="r-radio"><input type="radio" name="kostenweg" value="schaetzen" /> <span>Bitte aus Listenpreisen schätzen</span></label>
        </fieldset>

        <div class="r-branch" id="r-branch-bekannt">
          <label>Ihre aktuelle oder angebotene VMware-Summe pro Jahr (€)
